# AeroNetB Environment Configuration
# Copy this file to .env and fill in your values

# PostgreSQL Connection
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=aeronetb
PG_USER=postgres
PG_PASSWORD=yourpassword

# MongoDB Connection
MONGO_URI=mongodb://localhost:27017
MONGO_DB=aeronetb

# JWT Secret (change this to a long random string)
JWT_SECRET=aeronetb_super_secret_jwt_key_change_in_production_2025

# Server
PORT=3000
NODE_ENV=development
